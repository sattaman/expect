{
  "name": "expect-sdk",
  "version": "0.0.26",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/millionco/expect",
    "directory": "packages/typescript-sdk"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./effect": {
      "import": {
        "types": "./dist/effect.d.mts",
        "default": "./dist/effect.mjs"
      }
    }
  },
  "publishConfig": {
    "tag": "alpha"
  },
  "scripts": {
    "lint": "vp lint && tsc --noEmit",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "build": "vp pack",
    "check": "vp check",
    "test": "vp test run",
    "test:e2e": "~/.bun/bin/bun tests/e2e.ts",
    "test:watch": "vp test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.35",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@standard-schema/spec": "^1.1.0",
    "effect": "4.0.0-beta.35"
  },
  "devDependencies": {
    "@expect/agent": "workspace:*",
    "@expect/browser": "workspace:*",
    "@expect/cookies": "workspace:*",
    "@expect/shared": "workspace:*",
    "@expect/supervisor": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.15.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "playwright": ">=1.50.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
