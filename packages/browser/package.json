{
  "name": "@expect/browser",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./cli": "./src/mcp/start.ts",
    "./cli-http": "./src/mcp/start-http.ts",
    "./runtime": "./src/runtime/index.ts"
  },
  "scripts": {
    "build:css": "mkdir -p dist && pnpm exec tailwindcss -i ./src/runtime/overlay/index.css -o ./dist/overlay.css -m && node scripts/css-rem-to-px.js && node scripts/inline-fonts.js",
    "build": "pnpm build:css && node scripts/build-runtime.js",
    "dev": "pnpm build:css && node scripts/build-runtime.js --watch",
    "lint": "vp lint && tsc --noEmit",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "test": "vp test run",
    "test:watch": "vp test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@effect/platform-node": "4.0.0-beta.35",
    "@expect/cookies": "workspace:*",
    "@expect/shared": "workspace:*",
    "@heroicons/react": "^2.2.0",
    "@medv/finder": "^4.0.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "accessibility-checker-engine": "^4.0.16",
    "effect": "4.0.0-beta.35",
    "playwright": "^1.52.0",
    "react": "^19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.2",
    "which": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/which": "^3.0.4",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
